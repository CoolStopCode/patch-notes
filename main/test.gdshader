void fragment() {
	vec4 tex_color = texture(TEXTURE, UV);
	if (!enabled) {
		COLOR = tex_color;
	} else {
	float lowest_sum = 9999.0;
	vec4 lowest_color = vec4(0.0, 0.0, 0.0, 1.0);
	int lowest_item = 0;
	for (int i = 0; i < 49; i++) {
		float r = abs(colors[i].r - tex_color.r);
		float g = abs(colors[i].g - tex_color.g);
		float b = abs(colors[i].b - tex_color.b);
		float sum = r + g + b;
		if (sum < lowest_sum) {
			lowest_sum = sum;
			lowest_item = i;
			lowest_color = vec4(r, g, b, 1.0);
		}
	}
	
	COLOR = colors[lowest_item];
}}
