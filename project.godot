; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Patch Notes"
run/main_scene="uid://dtwykwm07uxi5"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

Constants="*res://global/constants.gd"
Cursor="*res://global/cursor.gd"
ConnectionManager="*res://global/connection_manager.gd"
GlobalNodes="*uid://cejucmy7okxjl"
Save="*uid://dehjvdhsukuxm"
Load="*uid://umulofxvg8t0"
History="*uid://b1podmnco7lxw"
NodeThread="*uid://cqgk8ffq1o48n"

[debug]

gdscript/warnings/unused_variable=0
gdscript/warnings/unused_parameter=0
gdscript/warnings/unused_signal=0

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/initial_position=Vector2i(0, -200)
window/size/always_on_top=true

[file_customization]

folder_colors={
"res://assets/": "yellow",
"res://classes/": "gray",
"res://dev/": "red",
"res://global/": "gray",
"res://inspector/": "blue",
"res://main/": "pink",
"res://node/": "purple",
"res://nodes/": "green"
}

